# The app calls the backend via relative "/api" URLs (proxied by Vite in dev, nginx in prod),
# so normally you do NOT need to set anything here.
#
# Set VITE_API_URL only if you want the bundle to call a backend on a different origin directly
# (bypassing the proxy). It is read at build time.
# VITE_API_URL=https://your-backend.example.com
